        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-155" value="Postman sends SYN&lt;div&gt;&lt;div&gt;say SEQ = 1000&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
