        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-73" value="4" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e51400;fontColor=#ffffff;strokeColor=#B20000;" parent="1" vertex="1">
          <mxGeometry x="795" y="2100" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-74" value="&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;Postman sends&lt;/span&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1.Supported TLS version (e.g., TLS 1.2, TLS 1.3)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2.Supported cipher suites (e.g., AES_256_GCM_SHA384)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;3.A random number, say:&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ClientRandom = 0xA1B2C3D4E5F6&lt;/span&gt;&lt;/div&gt;&lt;div&gt;4.Extensions (like SNI to tell the hostname&amp;nbsp;&lt;code data-end=&quot;1829&quot; data-start=&quot;1818&quot;&gt;localhost&lt;/code&gt;)&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="820" y="2100" width="410" height="80" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-75" value="" style="shape=mxgraph.networks2.icon;aspect=fixed;fillColor=#EDEDED;strokeColor=#000000;gradientColor=#5B6163;network2IconShadow=1;network2bgFillColor=none;network2Icon=mxgraph.networks2.laptop;network2IconW=1;network2IconH=0.5734;" parent="1" vertex="1">
          <mxGeometry x="211.13" y="2000" width="174.4" height="100" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-76" value="" style="image;html=1;image=img/lib/clip_art/computers/Server_128x128.png" parent="1" vertex="1">
          <mxGeometry x="274.46" y="2010" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-77" value="Tomcat server" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="250.82999999999998" y="2050" width="95" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-79" value="5" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e51400;fontColor=#ffffff;strokeColor=#B20000;" parent="1" vertex="1">
          <mxGeometry x="200" y="2120" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-80" value="&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;Tomcat server sends&lt;/span&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Selected TLS version (say TLS 1.2)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2.&lt;/span&gt;Selected cipher suite (e.g., AES_256_GCM_SHA384)&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;3.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Its own random number, say:&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;ServerRandom = 0x1F2E3D4C5B6A&lt;/span&gt;&lt;/div&gt;&lt;div&gt;4.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The &lt;/span&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;2162&quot; data-start=&quot;2143&quot;&gt;SSL certificate&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; from &lt;/span&gt;&lt;code style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;2182&quot; data-start=&quot;2168&quot;&gt;keystore.p12&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; (contains public key)&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="230" y="2120" width="410" height="80" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-82" value="6" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e51400;fontColor=#ffffff;strokeColor=#B20000;" parent="1" vertex="1">
          <mxGeometry x="790" y="2280" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-84" value="Postman checks the server&#39;s certificate&lt;div&gt;&amp;nbsp;1. Is it valid for localhost?&lt;/div&gt;&lt;div&gt;&amp;nbsp;2.&amp;nbsp;Is it from a trusted CA? (If self-signed, Postman warns you.)&lt;/div&gt;&lt;div&gt;You accept the warning (if self-signed) or continue.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="815" y="2280" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-85" value="&lt;b&gt;PreMasterSecret generation&lt;/b&gt;&lt;div&gt;Postman generates a secret say:&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;PreMasterSecret = 0x9988776655443322 (48 byte)&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="815" y="2350" width="495" height="40" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-86" value="Postman encrypts PreMasterSecret&amp;nbsp; using server public key&lt;div&gt;Postman sends this encrypted PreMasterSecret to the server.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="815" y="2390" width="415" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-87" value="Spring boot uses its private key to decrypt PreMasterSecret." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="230" y="2275" width="410" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-88" value="7" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e51400;fontColor=#ffffff;strokeColor=#B20000;" parent="1" vertex="1">
          <mxGeometry x="200" y="2280" width="20" height="20" as="geometry" />
