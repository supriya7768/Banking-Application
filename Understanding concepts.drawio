          <mxGeometry x="583.33" y="2520" width="50" height="31" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-93" value="Both side have&lt;div&gt;1.ClientRandom =&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0xA1B2C3D4E5F6&lt;/span&gt;&lt;/div&gt;&lt;div&gt;2.ServerRandom =&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0x1F2E3D4C5B6A&lt;/span&gt;&lt;/div&gt;&lt;div&gt;3.PreMasterSecret =&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0x9988776655443322&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="700" y="2530" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-94" value="Both sides now run the &lt;strong data-end=&quot;1871&quot; data-start=&quot;1839&quot;&gt;same key derivation function&lt;/strong&gt;:&lt;div&gt;&lt;div&gt;MasterSecret = PRF(PreMasterSecret, &quot;master secret&quot;, ClientRandom + ServerRandom)&lt;/div&gt;&lt;/div&gt;&lt;div&gt;(PRF = Pseudo-Random Function defined by TLS)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;MasterSecret might be&amp;nbsp;9E56AB784321FFAA...&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="321.25" y="2640" width="527.5" height="85" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-95" value="8" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e51400;fontColor=#ffffff;strokeColor=#B20000;" parent="1" vertex="1">
          <mxGeometry x="295" y="2645" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-117" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="KBjdMgGRRg1gwqXxhLQQ-97" target="KBjdMgGRRg1gwqXxhLQQ-116" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1059" y="2835" />
              <mxPoint x="1059" y="2960" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-97" value="&lt;div&gt;This Master Secret will be used to generate &lt;strong data-end=&quot;1839&quot; data-start=&quot;1823&quot;&gt;session keys&lt;/strong&gt; for encryption.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;Symmetric encryption keys are derived from MasterSecret&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;code data-end=&quot;2292&quot; data-start=&quot;2272&quot;&gt;Key_ClientToServer&lt;/code&gt; (encrypts your request body)&lt;/div&gt;&lt;div&gt;&lt;code data-end=&quot;2344&quot; data-start=&quot;2324&quot;&gt;Key_ServerToClient&lt;/code&gt; (encrypts the response)&lt;/div&gt;&lt;div style=&quot;&quot;&gt;MAC keys for verifying message integrity&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="310.67" y="2790" width="408.33" height="90" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-98" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="KBjdMgGRRg1gwqXxhLQQ-94" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="2787" as="targetPoint" />
            <Array as="points">
              <mxPoint x="410" y="2787" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-99" value="Now encryption switches to &lt;strong data-end=&quot;2497&quot; data-start=&quot;2484&quot;&gt;symmetric&lt;/strong&gt; (AES, ChaCha20, etc.) because it’s much faster than public/private key encryption.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Both Postman and Spring Boot send encrypted “Finished” messages, confirming handshake success.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="303.33" y="2920" width="456.67" height="80" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-100" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410.33" y="2880" as="sourcePoint" />
            <mxPoint x="410" y="2912" as="targetPoint" />
            <Array as="points">
              <mxPoint x="410" y="2912" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-101" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="841" y="3060" width="99" height="87.29" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-102" value="" style="shape=mxgraph.networks2.icon;aspect=fixed;fillColor=#EDEDED;strokeColor=#000000;gradientColor=#5B6163;network2IconShadow=1;network2bgFillColor=none;network2Icon=mxgraph.networks2.laptop;network2IconW=1;network2IconH=0.5734;" parent="1" vertex="1">
          <mxGeometry x="255.6" y="3060" width="174.4" height="100" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-103" value="" style="image;html=1;image=img/lib/clip_art/computers/Server_128x128.png" parent="1" vertex="1">
          <mxGeometry x="318.92999999999995" y="3070" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-104" value="Tomcat server" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="295.29999999999995" y="3110" width="95" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-105" value="Postman now sends the actual HTTP request:&lt;div&gt;&lt;br&gt;&lt;div&gt;&lt;div&gt;GET /hello HTTP/1.1&lt;/div&gt;&lt;div&gt;Host: localhost:8443&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="846.25" y="3190" width="527.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-106" value="9" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e51400;fontColor=#ffffff;strokeColor=#B20000;" parent="1" vertex="1">
          <mxGeometry x="820" y="3185" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-107" value="&lt;div&gt;&lt;div&gt;But this data is encrypted by MasterSecret (session key) - on wire it is gibberish&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="846.25" y="3250" width="527.5" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-108" value="&lt;div&gt;&lt;div&gt;Spring boot decrypts the binary gibberish by using same session key.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;It reconstructs the original HTTP request.&lt;/div&gt;&lt;div&gt;Finds your &lt;code data-end=&quot;2511&quot; data-start=&quot;2488&quot;&gt;@GetMapping(&quot;/hello&quot;)&lt;/code&gt; method&lt;/div&gt;&lt;div&gt;Executes it and produces the plain response body:&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="235.00000000000003" y="3185" width="527.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-110" value="10" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e51400;fontColor=#ffffff;strokeColor=#B20000;" parent="1" vertex="1">
          <mxGeometry x="210" y="3185" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-111" value="&lt;div&gt;&lt;div&gt;But before sending spring boot encrpyts&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;HTTP/1.1 200 OK&lt;/div&gt;&lt;div&gt;Content-Type: text/plain&lt;/div&gt;&lt;div&gt;Content-Length: 5&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Hello&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Again, the encrypted form looks like gibberish over the wire.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="235" y="3270" width="405" height="140" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-112" value="&lt;div&gt;&lt;div&gt;Postman receives the encrypted bytes.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Decrypts them using the session key.&lt;/div&gt;&lt;div&gt;Gets back : Hello&lt;/div&gt;&lt;div&gt;Displays Hello in its response panel.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="840" y="3450" width="527.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-113" value="11" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#e51400;fontColor=#ffffff;strokeColor=#B20000;" parent="1" vertex="1">
          <mxGeometry x="815" y="3450" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-114" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="384" y="3550" width="596" height="128" as="geometry" />
        </mxCell>
