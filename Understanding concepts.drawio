          <mxGeometry x="90.5" y="3917.5" width="79" height="25" as="geometry" />
        </mxCell>
        <mxCell id="gleh70Z9XqgxIAuWuITA-8" value="&lt;div&gt;# Generate client keystore (client private key + certificate)&lt;/div&gt;&lt;div&gt;keytool -genkeypair -alias client -keyalg RSA -keysize 2048 -keystore client-keystore.jks -validity 3650&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="94.5" y="4060" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="gleh70Z9XqgxIAuWuITA-9" value="&lt;div&gt;# Generate server keystore (server private key + certificate)&lt;/div&gt;&lt;div&gt;keytool -genkeypair -alias server -keyalg RSA -keysize 2048 -keystore server-keystore.jks -validity 3650&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="95" y="3970" width="560" height="30" as="geometry" />
        </mxCell>
        <mxCell id="gleh70Z9XqgxIAuWuITA-10" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;# Export server certificate&lt;/div&gt;&lt;div&gt;keytool -exportcert -alias server -file server-cert.cer -keystore server-keystore.jks&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="94.5" y="4010" width="570" height="30" as="geometry" />
        </mxCell>
        <mxCell id="gleh70Z9XqgxIAuWuITA-11" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;# Export client certificate&lt;/div&gt;&lt;div&gt;keytool -exportcert -alias client -file client-cert.cer -keystore client-keystore.jks&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="95" y="4090" width="489.5" height="30" as="geometry" />
        </mxCell>
        <mxCell id="gleh70Z9XqgxIAuWuITA-12" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;# Create server truststore and import client cert&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;keytool -importcert -alias client -file client-cert.cer -keystore server-truststore.jks&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="81.66" y="4130" width="446.67" height="30" as="geometry" />
        </mxCell>
        <mxCell id="gleh70Z9XqgxIAuWuITA-13" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;# Create client truststore and import servercert&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;div&gt;keytool -importcert -alias server -file server-cert.cer -keystore client-truststore.jks&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="81.66" y="4180" width="446.67" height="30" as="geometry" />
        </mxCell>
        <mxCell id="gleh70Z9XqgxIAuWuITA-14" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;# To convert .jks to .p12 to add certificate in postman&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;keytool -importkeystore -srckeystore client-keystore.jks -destkeystore client-keystore.p12 -deststoretype PKCS12&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="89" y="4210" width="610" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
