  <diagram name="SSL / TLS" id="Kp0G-0KwBIRjmfgeyEyl">
    <mxGraphModel dx="2907" dy="3003" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-115" value="" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="90" y="1380" width="1270" height="2350" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-137" value="" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="335.6700000000001" y="1780" width="449.33" height="169" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-32" value="" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="60" y="-1090" width="1390" height="710" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-35" value="" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="1020" y="-1057.5" width="280" height="397.5" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-34" value="" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="160" y="-1070" width="430" height="410" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-3" value="" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="20" y="340" width="790" height="430" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-2" value="" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="30" y="350" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-1" value="&lt;h4&gt;&lt;span style=&quot;font-size: 16px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Process to get a certificate&lt;/span&gt;&lt;/h4&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="40" y="350" width="210" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-4" value="&lt;pre&gt;keytool -genkeypair -alias mycert -keyalg RSA -keysize 2048 -storetype PKCS12 -keystore keystore.p12 -validity 3650&lt;/pre&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="410" width="670" height="40" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-6" value="&lt;ul&gt;&lt;li&gt;Add the below code snippet in your project terminal&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="390" width="330" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-7" value="&lt;ul&gt;&lt;li&gt;Fill the information such as password, first and last name, organization unit, organization name, city,&amp;nbsp; state, country&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="450" width="690" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-8" value="&lt;ul&gt;&lt;li&gt;Now the file of keystore.p12 will be created in your project which contains the private key and self-assigned certificate.&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="480" width="690" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-9" value="&lt;ul&gt;&lt;li&gt;Move this keystore.p12 file in src/main/resources&amp;nbsp;&lt;span style=&quot;color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px; text-wrap-mode: nowrap;&quot;&gt;%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20value%3D%22%26lt%3Bul%26gt%3B%26lt%3Bli%26gt%3BNow%20the%20file%20of%20keystore.p12%20will%20be%20created%20in%20your%20project%20which%20contains%20the%20private%20key%20and%20self-assigned%20certificate.%26lt%3B%2Fli%26gt%3B%26lt%3B%2Ful%26gt%3B%22%20style%3D%22text%3Bhtml%3D1%3Balign%3Dleft%3BverticalAlign%3Dmiddle%3BwhiteSpace%3Dwrap%3Brounded%3D0%3B%22%20vertex%3D%221%22%20parent%3D%221%22%3E%3CmxGeometry%20x%3D%2210%22%20y%3D%22150%22%20width%3D%22690%22%20height%3D%2230%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3C%2Froot%3E%3C%2FmxGraphModel%3E&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="510" width="690" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-10" value="&lt;ul&gt;&lt;li&gt;In application.properties add this&lt;br&gt;&lt;div style=&quot;background-color:#1e1f22;color:#bcbec4&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;server.port&lt;/span&gt;&lt;span style=&quot;color:#808080;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color:#6aab73;&quot;&gt;8443&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;server.ssl.enabled&lt;/span&gt;&lt;span style=&quot;color:#808080;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color:#6aab73;&quot;&gt;true&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;server.ssl.key-store&lt;/span&gt;&lt;span style=&quot;color:#808080;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color:#6aab73;&quot;&gt;classpath:keystore.p12&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;server.ssl.key-store-password&lt;/span&gt;&lt;span style=&quot;color:#808080;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color:#6aab73;&quot;&gt;bntsoft@12&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;server.ssl.key-store-type&lt;/span&gt;&lt;span style=&quot;color:#808080;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color:#6aab73;&quot;&gt;PKCS12&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;server.ssl.key-alias&lt;/span&gt;&lt;span style=&quot;color:#808080;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color:#6aab73;&quot;&gt;mycert&lt;/span&gt;&lt;/pre&gt;&lt;/div&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px; text-wrap-mode: nowrap;&quot;&gt;%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20value%3D%22%26lt%3Bul%26gt%3B%26lt%3Bli%26gt%3BMove%20this%20keystore.p12%20file%20in%20src%2Fmain%2Fresources%26amp%3Bnbsp%3B%26lt%3Bspan%20style%3D%26quot%3Bcolor%3A%20rgba(0%2C%200%2C%200%2C%200)%3B%20font-family%3A%20monospace%3B%20font-size%3A%200px%3B%20text-wrap-mode%3A%20nowrap%3B%26quot%3B%26gt%3B%253CmxGraphModel%253E%253Croot%253E%253CmxCell%2520id%253D%25220%2522%252F%253E%253CmxCell%2520id%253D%25221%2522%2520parent%253D%25220%2522%252F%253E%253CmxCell%2520id%253D%25222%2522%2520value%253D%2522%2526lt%253Bul%2526gt%253B%2526lt%253Bli%2526gt%253BNow%2520the%2520file%2520of%2520keystore.p12%2520will%2520be%2520created%2520in%2520your%2520project%2520which%2520contains%2520the%2520private%2520key%2520and%2520self-assigned%2520certificate.%2526lt%253B%252Fli%2526gt%253B%2526lt%253B%252Ful%2526gt%253B%2522%2520style%253D%2522text%253Bhtml%253D1%253Balign%253Dleft%253BverticalAlign%253Dmiddle%253BwhiteSpace%253Dwrap%253Brounded%253D0%253B%2522%2520vertex%253D%25221%2522%2520parent%253D%25221%2522%253E%253CmxGeometry%2520x%253D%252210%2522%2520y%253D%2522150%2522%2520width%253D%2522690%2522%2520height%253D%252230%2522%2520as%253D%2522geometry%2522%252F%253E%253C%252FmxCell%253E%253C%252Froot%253E%253C%252FmxGraphModel%253E%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fli%26gt%3B%26lt%3B%2Ful%26gt%3B%22%20style%3D%22text%3Bhtml%3D1%3Balign%3Dleft%3BverticalAlign%3Dmiddle%3BwhiteSpace%3Dwrap%3Brounded%3D0%3B%22%20vertex%3D%221%22%20parent%3D%221%22%3E%3CmxGeometry%20x%3D%2210%22%20y%3D%22180%22%20width%3D%22690%22%20height%3D%2230%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3C%2Froot%3E%3C%2FmxGraphModel%3E&lt;/span&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px; text-wrap-mode: nowrap;&quot;&gt;%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20value%3D%22%26lt%3Bul%26gt%3B%26lt%3Bli%26gt%3BMove%20this%20keystore.p12%20file%20in%20src%2Fmain%2Fresources%26amp%3Bnbsp%3B%26lt%3Bspan%20style%3D%26quot%3Bcolor%3A%20rgba(0%2C%200%2C%200%2C%200)%3B%20font-family%3A%20monospace%3B%20font-size%3A%200px%3B%20text-wrap-mode%3A%20nowrap%3B%26quot%3B%26gt%3B%253CmxGraphModel%253E%253Croot%253E%253CmxCell%2520id%253D%25220%2522%252F%253E%253CmxCell%2520id%253D%25221%2522%2520parent%253D%25220%2522%252F%253E%253CmxCell%2520id%253D%25222%2522%2520value%253D%2522%2526lt%253Bul%2526gt%253B%2526lt%253Bli%2526gt%253BNow%2520the%2520file%2520of%2520keystore.p12%2520will%2520be%2520created%2520in%2520your%2520project%2520which%2520contains%2520the%2520private%2520key%2520and%2520self-assigned%2520certificate.%2526lt%253B%252Fli%2526gt%253B%2526lt%253B%252Ful%2526gt%253B%2522%2520style%253D%2522text%253Bhtml%253D1%253Balign%253Dleft%253BverticalAlign%253Dmiddle%253BwhiteSpace%253Dwrap%253Brounded%253D0%253B%2522%2520vertex%253D%25221%2522%2520parent%253D%25221%2522%253E%253CmxGeometry%2520x%253D%252210%2522%2520y%253D%2522150%2522%2520width%253D%2522690%2522%2520height%253D%252230%2522%2520as%253D%2522geometry%2522%252F%253E%253C%252FmxCell%253E%253C%252Froot%253E%253C%252FmxGraphModel%253E%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fli%26gt%3B%26lt%3B%2Ful%26gt%3B%22%20style%3D%22text%3Bhtml%3D1%3Balign%3Dleft%3BverticalAlign%3Dmiddle%3BwhiteSpace%3Dwrap%3Brounded%3D0%3B%22%20vertex%3D%221%22%20parent%3D%221%22%3E%3CmxGeometry%20x%3D%2210%22%20y%3D%22180%22%20width%3D%22690%22%20height%3D%2230%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3C%2Froot%3E%3C%2FmxGraphModel%3E&lt;/span&gt;&lt;br&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="540" width="690" height="160" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-11" value="Here keep your password" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="450" y="620" width="155" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="KBjdMgGRRg1gwqXxhLQQ-11" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="380" y="630" as="targetPoint" />
            <Array as="points" />
          </mxGeometry>
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-13" value="&lt;ul&gt;&lt;li&gt;Run your application&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="690" width="690" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-14" value="&lt;ul&gt;&lt;li&gt;Open in&lt;span style=&quot;color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px; text-wrap-mode: nowrap;&quot;&gt;%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20value%3D%22%26lt%3Bul%26gt%3B%26lt%3Bli%26gt%3BRun%20your%20application%26lt%3B%2Fli%26gt%3B%26lt%3B%2Ful%26gt%3B%22%20style%3D%22text%3Bhtml%3D1%3Balign%3Dleft%3BverticalAlign%3Dmiddle%3BwhiteSpace%3Dwrap%3Brounded%3D0%3B%22%20vertex%3D%221%22%20parent%3D%221%22%3E%3CmxGeometry%20x%3D%2210%22%20y%3D%22360%22%20width%3D%22690%22%20height%3D%2230%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3C%2Froot%3E%3C%2FmxGraphModel%3E&lt;/span&gt;&amp;nbsp;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 51), rgb(237, 237, 237));&quot;&gt; https://localhost:8443&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="710" width="690" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-16" value="" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="20" y="810" width="850" height="300" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-17" value="When we ran&lt;div&gt;&lt;pre&gt;keytool -genkeypair -alias mycert -keyalg RSA -keysize 2048 -storetype PKCS12 -keystore keystore.p12 -validity 3650&lt;br/&gt;&lt;br&gt;&lt;/pre&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="830" width="760" height="40" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-18" value="we told java that&amp;nbsp;&lt;br&gt;“Generate a public/private key pair and wrap it inside a self-signed certificate, then store it securely in a file (&lt;code data-end=&quot;439&quot; data-start=&quot;425&quot;&gt;keystore.p12&lt;/code&gt;) that uses PKCS12 format.”" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="870" width="820" height="50" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-21" value="This&amp;nbsp;&lt;strong data-end=&quot;485&quot; data-start=&quot;473&quot;&gt;keystore&lt;/strong&gt;&amp;nbsp;is like a secure vault containing&lt;div style=&quot;text-align: left;&quot;&gt;&lt;ul&gt;&lt;li data-end=&quot;594&quot; data-start=&quot;521&quot;&gt;&lt;p data-end=&quot;594&quot; data-start=&quot;523&quot;&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;611&quot; data-start=&quot;597&quot;&gt;Public key&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;→ used by clients to encrypt data for you&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-end=&quot;594&quot; data-start=&quot;521&quot;&gt;&lt;p data-end=&quot;594&quot; data-start=&quot;523&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;strong style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; background-color: transparent;&quot; data-end=&quot;538&quot; data-start=&quot;523&quot;&gt;Private key&lt;/strong&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; background-color: transparent;&quot;&gt;&amp;nbsp;→ your secret encryption key (never shared with anyone)&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-end=&quot;594&quot; data-start=&quot;521&quot;&gt;&lt;p data-end=&quot;594&quot; data-start=&quot;523&quot;&gt;&lt;strong style=&quot;text-align: center; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;683&quot; data-start=&quot;656&quot;&gt;Self-signed certificate&lt;/strong&gt;&lt;span style=&quot;text-align: center; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;→ says “this is my identity” (signed by you)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="20" y="930" width="420" height="130" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-22" value="By placing &lt;code data-start=&quot;791&quot; data-end=&quot;805&quot;&gt;keystore.p12&lt;/code&gt; inside your resources, you made it available on your app’s classpath.&lt;br data-start=&quot;875&quot; data-end=&quot;878&quot;&gt;&lt;br&gt;This allows Spring Boot’s embedded Tomcat server to load it when starting." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="30" y="1050" width="520" height="50" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-23" value="" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="20" y="1150" width="520" height="200" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-24" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="30" y="1160" width="483" height="170.39" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-25" value="" style="sketch=0;aspect=fixed;pointerEvents=1;shadow=0;dashed=0;html=1;strokeColor=none;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;align=center;fillColor=#00188D;shape=mxgraph.azure.laptop" parent="1" vertex="1">
          <mxGeometry x="180" y="-1050" width="383.33" height="230" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-26" value="" style="image;aspect=fixed;html=1;points=[];align=center;fontSize=12;image=img/lib/azure2/compute/Azure_Spring_Cloud.svg;" parent="1" vertex="1">
          <mxGeometry x="250" y="-1020" width="80" height="80" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-27" value="Tomcat" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=27;" parent="1" vertex="1">
          <mxGeometry x="225" y="-920" width="140" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-28" value="Server" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=27;" parent="1" vertex="1">
          <mxGeometry x="305" y="-650" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-30" value="" style="dashed=0;outlineConnect=0;html=1;align=center;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;shape=mxgraph.weblogos.chrome" parent="1" vertex="1">
          <mxGeometry x="1100" y="-1030" width="74.8" height="75.4" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-31" value="Client" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=27;" parent="1" vertex="1">
          <mxGeometry x="1100" y="-650" width="60" height="30" as="geometry" />
        </mxCell>
