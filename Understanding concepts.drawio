          <mxGeometry x="932.5" y="1620" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-124" value="Leader" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="927.5" y="1450" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-125" value="Kafka copies partitions to other brokers." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="880" y="1710" width="296" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-126" value="If Broker 1 crashes :&lt;div&gt;&lt;ul&gt;&lt;li&gt;Broker 2 becomes leader&lt;/li&gt;&lt;li&gt;No data loss&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="877.25" y="1740" width="296" height="70" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-127" value="&lt;div&gt;1. Producer sends message&lt;/div&gt;&lt;div&gt;2. Message goes to Topic&lt;/div&gt;&lt;div&gt;3. Stored in a Partition&lt;/div&gt;&lt;div&gt;4. Saved on Broker disk&lt;/div&gt;&lt;div&gt;5. Consumer reads using offset&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="-85.63" y="2170" width="176" height="90" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-130" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a0522d;strokeColor=#6D1F00;fontColor=#ffffff;" parent="1" vertex="1">
          <mxGeometry x="25.25" y="-100" width="234.75" height="60" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-131" value="&lt;font style=&quot;color: light-dark(rgb(252, 247, 247), rgb(237, 237, 237));&quot;&gt;Kafka Architecture&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=21;" parent="1" vertex="1">
          <mxGeometry x="42.5" y="-85" width="187.5" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-133" value="&lt;div&gt;&lt;b style=&quot;line-height: 40%;&quot;&gt;Leader :&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Handles reads &amp;amp; writes&lt;/li&gt;&lt;li&gt;Producer writes here&lt;/li&gt;&lt;li&gt;Consumer reads from here&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Follower (Replica) :&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Just copies data&lt;/li&gt;&lt;li&gt;Stays in sync&lt;/li&gt;&lt;li&gt;Takes over if leader dies&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="870" y="1830" width="210" height="200" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-134" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="125.62000000000012" y="2160" width="307" height="263.37" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-135" value="It means position of a message inside a partition" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="1245" y="980" width="265" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-136" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="1245" y="1010.0000000000001" width="106" height="87.84" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-137" value="Kafka assigns offsets, not producers, not consumers." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="1245" y="1105" width="285" height="30" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-138" value="Offsets : Starts with zero&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Always increase&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Never change&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Never reused&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="1245" y="1135" width="285" height="45" as="geometry" />
        </mxCell>
        <mxCell id="H_yA-KdhFupQ0Z6lrMI9-139" value="Consumer stores it own offset.&lt;div&gt;Kafka does not remember who read the message and when it was read&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="1245" y="1210" width="285" height="40" as="geometry" />
        </mxCell>
