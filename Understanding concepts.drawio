        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-126" value="&lt;b&gt;Session Key&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="1500" y="2776.35" width="90" height="30" as="geometry" />
        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-127" value="Client Write key&lt;div&gt;Server Write Key&lt;/div&gt;&lt;div&gt;MAC keys&lt;/div&gt;&lt;div&gt;client_iv&lt;/div&gt;&lt;div&gt;server_iv&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
