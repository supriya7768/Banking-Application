        </mxCell>
        <mxCell id="KBjdMgGRRg1gwqXxhLQQ-135" value="Client write key used to decrypt data came from client&lt;div&gt;Server write key used to encrypt data send to the client&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
